%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Final_WineMaking
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: final-winemaking
  moduleTitle: 'Final 4: Wine Making'
  intendedLearningOutcomes:
  - Prepare a fermenting must from fruit, sugar and yeast
  - Confirm fermentation by CO2 evolution (limewater)
  - Rack and evaluate the finished wine (appearance, clarity, flavour)
  materialReagents:
  - "Mixed Fruit Juice \u2014 250 mL min (tilt-pour to 40 ml)"
  - "Brown Sugar \u2014 3 scoopula dips (feeds the yeast)"
  - "Ammonium Phosphate \u2014 1 dip (yeast nutrient)"
  - "Yeast \u2014 2 scoopula dips (the fermenting catalyst)"
  - "Limewater \u2014 10 ml (CO2 confirmation)"
  materialApparatus:
  - "Fermentation Jar - Beaker 500 mL (the must)"
  - "Glass rod (rouse the yeast)"
  - "Test Tube 5 (limewater CO2 check)"
  - "Racking funnel + Wine Bottle - Florence flask"
  - "Watch Glass (clarity) \u00B7 Beaker 100 mL (tasting glass)"
  tasks: []
  graphTasks:
  - taskId: prepare-must
    label: "Prepare the must - fruit juice (NOT grapes) + sugar + yeast"
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "The manual: ferment at least 250 mL of any fruit juice EXCEPT grapes. Sugar feeds the yeast; a pinch of nutrient keeps it healthy.\n\u2192 Fermentation Jar: tilt-pour Mixed Fruit Juice to the 40 ml band, 3 scoopula dips of brown sugar, 1 dip of ammonium phosphate, then pitch 2 dips of yeast - watch the tag turn to 'Wine'."
  - taskId: stir-must
    label: "Swirl the must to rouse the yeast"
    phase: 0
    prerequisites:
    - prepare-must
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: "Rousing spreads the yeast evenly through the sugary juice so every part ferments.\n\u2192 Circle the GLASS ROD in the jar until the 'Well stirred!' cue shows."
  - taskId: confirm-ferment
    label: "Confirm fermentation - CO2 turns limewater milky"
    phase: 1
    prerequisites:
    - stir-must
    progressWeight: 1
    skill: 4
    rubricCategory: 0
    required: 1
    hint: "Fermenting wine gives off CO2 (that is what an airlock vents); leading that gas through limewater proves it is alive - the limewater turns milky (CaCO3).\n\u2192 Pour 10 ml of limewater into Test Tube 5 and hold it at the jar's mouth until it clouds - then the week-long ferment passes."
    longProcess: 1
    longProcessMessage: "Seven days and seven nights later - fermentation is complete and the wine has cleared over its lees."
  - taskId: rack
    label: "Rack the clear wine off the lees"
    phase: 1
    prerequisites:
    - confirm-ferment
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: "Racking siphons the clear wine off the sediment (lees) without disturbing it - the manual: 'do not shake; decant the liquid'.\n\u2192 Tilt-pour the clear wine from the jar THROUGH the racking funnel into the Wine Bottle (Florence flask) to the 30 ml band, leaving the lees behind."
  - taskId: test-clarity
    label: "Assess clarity, colour and appearance"
    phase: 2
    prerequisites:
    - rack
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "General appearance is a fifth of the wine-tasting grade - a bright, clear pour with no haze scores well.\n\u2192 Pour a splash (about 6 ml) of your racked wine onto the Watch Glass and judge its clarity against the light."
  - taskId: test-tasting
    label: "Tasting finale - evaluate aroma and flavour"
    phase: 2
    prerequisites:
    - rack
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Flavour, smell and taste are a quarter of the grade - the tasting finale of the whole course.\n\u2192 Pour about 12 ml into the Tasting Glass and evaluate the aroma and flavour."
  - taskId: record-label
    label: "Create the label & record volume and observations"
    phase: 3
    prerequisites:
    - test-clarity
    - test-tasting
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: "Design the bottle label and log the final volume (250-500 mL) with your appearance and tasting notes.\n\u2192 Review your wine, then answer on the tablet."
    autoCompleteWhenOthersDone: 1
  assessmentMode: 0
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.2
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills:
  - 5
  - 0
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 600
