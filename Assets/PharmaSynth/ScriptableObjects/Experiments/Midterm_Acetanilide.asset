%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Midterm_Acetanilide
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: midterm-acetanilide
  moduleTitle: 'Midterm 2: Acetanilide'
  intendedLearningOutcomes:
  - Acetylate aniline to acetanilide in the fume hood
  - Isolate crystals by ice crystallisation and washing
  - Confirm the amide by hydrolysis and bromination tests
  materialReagents:
  - "Aniline \u2014 2 ml + 2 ml (FUME HOOD, both times)"
  - "Glacial Acetic Acid \u2014 2 ml (2 squeezes)"
  - "Acetyl Chloride \u2014 2 ml (FUME HOOD)"
  - "Distilled Water \u2014 ~20 ml (ice water) + 10 squeezes (tests)"
  - "Concentrated Hydrochloric Acid \u2014 3 squeezes (hydrolysis boil)"
  - "Hydrochloric Acid 0.1N \u2014 1 squeeze per bromination tube"
  - "Bromine Water \u2014 5 + 2 squeezes (compare the volumes!)"
  materialApparatus:
  - "Fume hood (aniline + acetyl chloride)"
  - "Florence flask (reaction)"
  - "Water bath + burner"
  - "Ice bucket"
  - "Funnel + Beaker 100 mL (collection)"
  - "Test tubes 11 / 12 / 13"
  - "Dropper"
  - "Scoopula (scoop your crystals)"
  tasks: []
  graphTasks:
  - taskId: prep-aniline
    label: "Measure aniline into the flask \u2014 in the FUME HOOD"
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "Aniline is toxic and volatile \u2014 it is only ever handled inside the fume hood.\n\u2192 Carry the Florence flask INTO the fume hood, then squeeze 2 dropper-loads of aniline into it there."
  - taskId: add-acetic
    label: "Add glacial acetic acid"
    phase: 1
    prerequisites:
    - prep-aniline
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "Glacial acetic acid moderates the vigorous acylation to come.\n\u2192 Squeeze 2 dropper-loads of glacial acetic acid into the flask."
  - taskId: acylate
    label: "Carefully add acetyl chloride; warm at the bath"
    phase: 1
    prerequisites:
    - add-acetic
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: "Acetyl chloride acylates aniline to ACETANILIDE \u2014 it reacts vigorously, which is why it stays in the hood.\n\u2192 In the fume hood, squeeze 2 dropper-loads of acetyl chloride in, then warm the flask at the water bath (~5 min)."
  - taskId: ice-crystallise
    label: "Add ice-cold water; chill to crystallise"
    phase: 1
    prerequisites:
    - acylate
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "Cold water crashes the acetanilide out of solution as white plates.\n\u2192 Tilt-pour about 20 ml of distilled water into the flask, then set it in the ice bucket."
  - taskId: filter-wash
    label: "Filter the crystals; wash and dry"
    phase: 1
    prerequisites:
    - ice-crystallise
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: "The crystals are caught on the filter; three water washes clean them, then they dry.\n\u2192 Hold the funnel over the Beaker 100 mL and tilt-pour the flask through it."
    longProcess: 1
    longProcessMessage: "Filtered, washed three times with water and dried \u2014 white acetanilide plates, ready to weigh for the data sheet."
  - taskId: test-hydrolysis
    label: "Hydrolysis test \u2014 boil with concentrated HCl"
    phase: 2
    prerequisites:
    - filter-wash
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Boiling in acid splits the amide; on cooling and dilution the crystals reappear.\n\u2192 Into Test Tube 11: 1 scoopula of your crystals + 3 squeezes of concentrated HCl, then boil it at the water bath."
  - taskId: test-bromination
    label: "Bromination \u2014 acetanilide vs free aniline"
    phase: 2
    prerequisites:
    - filter-wash
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "The COMPARISON is the lesson: the free amine takes bromine far faster than the amide.\n\u2192 Tube 12: 1 scoopula of crystals + 5 water + 1 of 0.1N HCl + 5 bromine water. Tube 13: 2 aniline (fume hood!) + 5 water + 1 of 0.1N HCl + 2 bromine water."
  - taskId: record-yield
    label: "Record % yield and observations"
    phase: 3
    prerequisites:
    - test-hydrolysis
    - test-bromination
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: "Crystal mass, % yield and both test results go on the data sheet.\n\u2192 Review the results, then answer on the tablet."
    autoCompleteWhenOthersDone: 1
  assessmentMode: 0
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.2
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills: 
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 900
