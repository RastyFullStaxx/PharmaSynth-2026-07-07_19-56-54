%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Tutorial_Methane
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: tutorial-methane
  moduleTitle: 'Tutorial: Methane Synthesis'
  intendedLearningOutcomes:
  - Assemble a gas-generation apparatus safely
  - Perform the decarboxylation of sodium acetate with soda lime
  - Collect a gas over water and confirm it by combustion
  - Follow lab safety and PPE throughout
  materialReagents:
  - "Sodium Acetate \u2014 4 g"
  - "Soda Lime \u2014 4 g"
  materialApparatus:
  - Scoopula
  - Mortar & pestle
  - Hard-glass tube
  - Burner
  - Collection tube
  - Matchsticks + striker box
  tasks: []
  graphTasks:
  - taskId: prepare-mixture
    label: Grind the mixture in the mortar
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "Scoop the sodium acetate + soda lime into the mortar, then GRAB THE PESTLE
      and grind in the bowl until it is a fine powder. (You do not move the powder
      into the tube \u2014 grinding is all this step needs.)"
  - taskId: setup-apparatus
    label: Load the mixture into the hard-glass tube
    phase: 1
    prerequisites:
    - prepare-mixture
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: "Scoop the ground mixture from the mortar into the \"Hard-glass tube\"
      \u2014 this is the tube you will heat. (Ignore the bent delivery tubes; they
      are not used.)"
  - taskId: heat-mixture
    label: Heat the hard-glass tube
    phase: 1
    prerequisites:
    - setup-apparatus
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: Grab a match and strike it on the matchbox, touch it to the burner to light
      it, then hold the lit burner under the "Hard-glass tube". Heating it makes
      the methane gas.
  - taskId: collect-gas
    label: Collect the gas in the collection tube
    phase: 1
    prerequisites:
    - heat-mixture
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: "Keep the \"Gas collection tube\" held against the heated \"Hard-glass
      tube\" \u2014 methane collects until the tube is full (a few seconds)."
  - taskId: test-gas
    label: Test the gas with a lit match
    phase: 2
    prerequisites:
    - collect-gas
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Light a match and bring it to the mouth of the full \"Gas collection tube\"
      \u2014 methane pops and burns with a pale blue flame. Test complete!"
  assessmentMode: 0
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.2
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills: 00000000030000000100000005000000
  rubricWeights:
