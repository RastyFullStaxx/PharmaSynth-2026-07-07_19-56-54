%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Prelim_ChemicalCompounding
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: prelim-chemical-compounding
  moduleTitle: 'Prelim: Chemical Compounding'
  intendedLearningOutcomes:
  - Write chemical reactions involved in some organic compounds such as alcohols,
    aldehydes, ketones, carboxylic acids and esters
  - Differentiate tests for different organic compounds
  materialReagents:
  - "Distilled Water \u2014 60 ml"
  - "Ferric Chloride 10% \u2014 29 ml"
  - "Potassium Permanganate 0.1% \u2014 16 ml"
  - "Ethanol \u2014 11 ml"
  - "n-Butyl Alcohol \u2014 11 ml"
  - "sec-Butyl Alcohol \u2014 10 ml"
  - "tert-Butyl Alcohol \u2014 10 ml"
  - "Methanol \u2014 10 ml"
  - "Sodium Hydroxide 6N \u2014 8 ml"
  - "Sulfuric Acid 6N \u2014 8 ml"
  - "Salicylic Acid \u2014 5.1 g"
  - "Tollen's Reagent \u2014 4 ml"
  - "Diluted Acetic Acid \u2014 4 ml"
  - "Acetone \u2014 2 ml"
  - "Acetaldehyde \u2014 2 ml"
  - "Sulfuric Acid \u2014 2 ml"
  - "Benzyl Alcohol \u2014 1 ml"
  - "Phenol \u2014 1 ml"
  - "Glycerol \u2014 1 ml"
  - "Aspirin \u2014 1 g"
  - "Concentrated Hydrochloric Acid \u2014 1 ml"
  materialApparatus:
  - "Test tubes \xD7 19"
  - "Tube holders \xD7 4"
  - "Droppers \xD7 4"
  - Porcelain spatula
  - Beaker 100 mL
  - Funnel + filter paper
  - Bunsen burner + matches
  - Water bath
  tasks: []
  graphTasks:
  - taskId: prep-enol-tubes
    label: Set up the enol-test tubes (5 alcohols)
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "Place 1 ml each of Ethanol, n-Butyl Alcohol, Benzyl Alcohol, Phenol and
      Glycerol into five separate test tubes, then dilute each with 10 ml of distilled
      water.\n\u2192 Dropper = 1 squeeze per ml: one squeeze of its OWN sample into
      each labelled tube, then tilt-pour distilled water to the 10 ml mark. All five
      tubes."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: test-enol-fecl3
    label: Enol test - add ferric chloride to each tube
    phase: 2
    prerequisites:
    - prep-enol-tubes
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Add 5 drops of 10% Ferric Chloride to each of the five tubes and compare
      the colours.\n\u2192 5 squeezes of the dropper over EVERY tube. Watch which
      one flashes violet - that is the enol."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: prep-oxidation-tubes
    label: Set up the rate-of-oxidation tubes (4 tubes)
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "Place 2 ml of 0.1% Potassium Permanganate and 2 drops of 6N Sodium Hydroxide
      in each of four test tubes.\n\u2192 2 squeezes of KMnO4, then 2 of Sodium Hydroxide,
      into all four tubes. This rack is the ALKALINE run."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: test-oxidation-alkaline
    label: Rate of oxidation in ALKALINE conditions
    phase: 2
    prerequisites:
    - prep-oxidation-tubes
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Add 5 drops of n-Butyl, sec-Butyl and tert-Butyl Alcohol to three of the
      tubes. Leave the fourth alone as a control. Note the time each takes to decolorise.\n\u2192
      5 squeezes into tubes 1-3, one alcohol each. Do NOT pour into tube 4 - the
      untouched control is part of the experiment."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: test-oxidation-acidic
    label: Rate of oxidation in ACIDIC conditions
    phase: 2
    prerequisites:
    - test-oxidation-alkaline
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Repeat using 2 ml of 0.1% Potassium Permanganate and 2 drops of 6N Sulfuric
      Acid, then the same three alcohols.\n\u2192 Same build on the second rack,
      acid instead of base: 2 squeezes of KMnO4, 2 of Sulfuric Acid, then 5 of each
      alcohol into tubes 1-3. Leave tube 4 alone again. Then compare both racks side
      by side."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: test-tollens
    label: Aldehyde vs ketone - Tollen's test
    phase: 2
    prerequisites:
    - test-oxidation-acidic
    progressWeight: 1
    skill: 1
    rubricCategory: 1
    required: 1
    hint: "Place 2 drops of Acetone and 2 drops of Acetaldehyde in separate test
      tubes, then add 2 ml of Tollen's reagent to both.\n\u2192 2 squeezes of the
      sample, then 2 of Tollen's, in BOTH tubes. Only the aldehyde plates a silver
      mirror."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: test-ester-acetate
    label: Ester formation - ethyl acetate
    phase: 2
    prerequisites:
    - test-tollens
    progressWeight: 1
    skill: 1
    rubricCategory: 1
    required: 1
    hint: "Place 10 drops of Ethanol, 4 drops of Diluted Acetic Acid and 1 drop of
      Concentrated Sulfuric Acid in a dry test tube, then warm it.\n\u2192 10 squeezes,
      then 4, then 1 - all three are needed; the acid is the catalyst. Then read
      the odour cue."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: test-ester-salicylate
    label: Ester formation - methyl salicylate
    phase: 2
    prerequisites:
    - test-ester-acetate
    progressWeight: 1
    skill: 1
    rubricCategory: 1
    required: 1
    hint: "Repeat using Methanol, 0.1 g of Salicylic Acid and Concentrated Sulfuric
      Acid.\n\u2192 10 squeezes of Methanol, ONE spatula dip of Salicylic Acid (a
      dip = 0.1 g), 1 squeeze of acid."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: prep-hydrolysis
    label: Hydrolyse the aspirin (boil in the water bath)
    phase: 2
    prerequisites:
    - test-ester-salicylate
    progressWeight: 1
    skill: 1
    rubricCategory: 1
    required: 1
    hint: "Place 0.5 g of Aspirin in a test tube, add 10 ml of distilled water and
      1 drop of Concentrated Hydrochloric Acid, then boil it in the water bath.\n\u2192
      5 spatula dips of Aspirin (0.1 g each), tilt-pour water to 10 ml, 1 squeeze
      of acid - then strike a match, light the burner and let it boil."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: filter-hydrolysate
    label: Filter off the undissolved crystals
    phase: 2
    prerequisites:
    - prep-hydrolysis
    progressWeight: 1
    skill: 2
    rubricCategory: 1
    required: 1
    hint: "Filter the boiled mixture and keep the filtrate.\n\u2192 Rest the funnel
      on the beaker and pour the boiled mixture through it."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: test-hydrolysis-fecl3
    label: Test the filtrate with ferric chloride
    phase: 2
    prerequisites:
    - filter-hydrolysate
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Add 2 drops of 10% Ferric Chloride to the filtrate. Violet means free
      Salicylic Acid - the ester has been hydrolysed.\n\u2192 2 squeezes into the
      filtrate beaker."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: test-hydrolysis-control
    label: Compare against UNhydrolysed aspirin
    phase: 2
    prerequisites:
    - test-hydrolysis-fecl3
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Repeat the ferric chloride test on plain, unboiled Aspirin and compare
      - no violet means the ester is still intact.\n\u2192 5 spatula dips of Aspirin
      into the control tube, then 2 squeezes of Ferric Chloride. The DIFFERENCE between
      the two tubes is the result."
    autoCompleteWhenOthersDone: 0
    longProcess: 0
    longProcessMessage: 
  - taskId: record-observations
    label: Record every colour and odour on the data sheet
    phase: 3
    prerequisites:
    - test-enol-fecl3
    - test-oxidation-acidic
    - test-tollens
    - test-ester-salicylate
    - test-hydrolysis-control
    progressWeight: 1
    skill: 5
    rubricCategory: 5
    required: 1
    hint: "Write up each test, the reaction involved and the colour or odour you
      observed.\n\u2192 The results board filled itself in as you worked - read it
      back, then answer on the tablet."
    autoCompleteWhenOthersDone: 1
    longProcess: 0
    longProcessMessage: 
  assessmentMode: 0
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.2
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills:
  - 5
  - 1
  - 0
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 900
