%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Final_Benzamide
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: final-benzamide
  moduleTitle: 'Final 1: Benzamide'
  intendedLearningOutcomes:
  - 'Objective 1: Synthesize benzamide.'
  - 'Objective 2: Determine its identity through chemical tests.'
  materialReagents:
  - "Ammonia Solution \u2014 5 ml (5 squeezes)"
  - "Benzoyl Chloride \u2014 1 ml (1 squeeze, into the COLD flask)"
  - "Sodium Hydroxide 10% \u2014 2 squeezes (alkali test)"
  - "Diluted Hydrochloric Acid \u2014 2 + 2 squeezes (acid + nitrous tests)"
  - "Sodium Nitrite 10% \u2014 3 squeezes (the manual's 'nitrate' typo)"
  - "Benzamide \u2014 your own crystals, 5 spatula dips per test"
  materialApparatus:
  - "Beaker 100 mL (the 50-ml reaction flask)"
  - "Ice bucket (controls the vigorous reaction)"
  - "Glass rod (shake/stir while adding)"
  - "Funnel + Watch Glass (filter, wash, oven-dry)"
  - "Test Tubes 15\u201317 (alkali / acid / nitrous)"
  - "Water bath + burner \u00B7 Balance \u00B7 Litmus strips"
  - "Dropper + porcelain spatula"
  tasks: []
  graphTasks:
  - taskId: measure-ammonia
    label: "Place 5 mL concentrated ammonia in the flask"
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "5 ml of concentrated ammonia is the amide's nitrogen source \u2014 sharp vapour, recap fast.\n\u2192 Beaker 100 mL (the 50-ml flask): 5 squeezes of ammonia solution."
  - taskId: ice-bath
    label: "Cool the flask in an ice bath"
    phase: 0
    prerequisites:
    - measure-ammonia
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: "Benzoyl chloride reacts VIOLENTLY with ammonia \u2014 the ice keeps it under control.\n\u2192 Set the beaker in the ice bucket until its label reads 5 \u00B0C."
  - taskId: add-benzoyl
    label: "Add 1 mL benzoyl chloride drop by drop"
    phase: 1
    prerequisites:
    - ice-bath
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: "One millilitre of benzoyl chloride, drop by drop into the COLD ammonia \u2014 white benzamide forms at once.\n\u2192 Dropper 1 squeeze of benzoyl chloride into the chilled beaker."
  - taskId: stir-stand
    label: "Shake while adding, then let stand 10\u201315 minutes"
    phase: 1
    prerequisites:
    - add-benzoyl
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: "The manual says shake frequently while dropping, then stand 10\u201315 minutes to crystallise fully.\n\u2192 Circle the GLASS ROD inside the beaker until 'Well stirred!' \u2014 then time passes."
    longProcess: 1
    longProcessMessage: "Fifteen minutes later \u2014 the beaker is packed with white benzamide crystals."
  - taskId: filter-dry
    label: "Filter, wash with cold water, oven-dry"
    phase: 1
    prerequisites:
    - stir-stand
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: "Filtering traps the crystals; a cold-water wash rinses off the mother liquor before the oven.\n\u2192 Tilt-pour 4 ml from the beaker through the funnel onto the Watch Glass."
    longProcess: 1
    longProcessMessage: "Filtered, washed with cold water and oven-dried \u2014 your benzamide is a dry white powder."
  - taskId: weigh-product
    label: "Weigh your benzamide crystals"
    phase: 1
    prerequisites:
    - filter-dry
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "The data sheet needs the crystal mass for the percentage yield.\n\u2192 Set the Watch Glass on the balance and let the reading settle."
  - taskId: test-alkali
    label: "Alkaline hydrolysis \u2014 ammonia turns red litmus BLUE"
    phase: 2
    prerequisites:
    - weigh-product
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Boiling with 10% NaOH hydrolyses the amide \u2014 the ammonia vapour turns RED litmus BLUE.\n\u2192 Test Tube 15: 5 spatula dips of your benzamide + 2 squeezes of sodium hydroxide 10%, warm it at the water bath, then touch a litmus strip to the tube."
  - taskId: test-acid
    label: "Acid hydrolysis \u2014 the tube reads ACID"
    phase: 2
    prerequisites:
    - weigh-product
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Boiling with dilute HCl hydrolyses it the other way \u2014 benzoic acid crystals separate and blue litmus turns RED.\n\u2192 Test Tube 16: 5 dips of your benzamide + 2 squeezes of diluted hydrochloric acid, warm it at the bath, then touch a litmus strip."
  - taskId: test-nitrous
    label: "Nitrous-acid test \u2014 brisk N2 effervescence"
    phase: 2
    prerequisites:
    - weigh-product
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Nitrous acid forms IN the tube from dilute HCl + sodium nitrite and deaminates the amide \u2014 brisk nitrogen effervescence. (The manual's 'nitrate' is a typo: NITRITE.)\n\u2192 Test Tube 17: 5 dips of your benzamide + 2 squeezes of diluted HCl, then 3 squeezes of sodium nitrite \u2014 watch it fizz."
  - taskId: record-yield
    label: "Record % yield and observations"
    phase: 3
    prerequisites:
    - weigh-product
    - test-alkali
    - test-acid
    - test-nitrous
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: "Crystal mass, % yield and all three test results go on the data sheet.\n\u2192 Review your observations, then answer on the tablet."
    autoCompleteWhenOthersDone: 1
  assessmentMode: 0
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.3
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills:
  - 0
  - 5
  - 2
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 900
