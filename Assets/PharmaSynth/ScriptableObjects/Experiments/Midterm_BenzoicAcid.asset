%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Midterm_BenzoicAcid
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: midterm-benzoic-acid
  moduleTitle: 'Midterm 1: Benzoic Acid'
  intendedLearningOutcomes:
  - 'Objective 1: Synthesize benzoic acid.'
  - 'Objective 2: Determine its identity through chemical tests.'
  materialReagents:
  - "Potassium Permanganate 0.1% \u2014 ~40 ml"
  - "Benzaldehyde \u2014 2 ml (2 squeezes)"
  - "Hydrochloric Acid 6N \u2014 5 squeezes"
  - "Distilled Water \u2014 a splash (litmus tube) + the water bath"
  - "Sodium Hydroxide 10% \u2014 2 squeezes"
  - "Ferric Chloride 10% \u2014 5 squeezes"
  - "Propyl Alcohol \u2014 10 squeezes"
  - "Sulfuric Acid \u2014 1 squeeze (a drop)"
  materialApparatus:
  - "Beaker 500 mL (reaction)"
  - "Erlenmeyer flask (filtrate)"
  - "Funnel"
  - "Test tubes 8 / 9 / 10"
  - "Dropper"
  - "Scoopula (scoop your crystals)"
  - "Water bath + burner"
  - "Ice bucket"
  - "Litmus paper"
  tasks: []
  graphTasks:
  - taskId: prepare-permanganate
    label: "Prepare the 0.1% permanganate oxidising bath"
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "The manuscript dissolves 0.1 g KMnO4 in 100 ml purified water \u2014 the shelf bottle IS that 0.1% solution.\n\u2192 Tilt-pour about 40 ml of it into the Beaker 500 mL."
  - taskId: oxidise-benzaldehyde
    label: "Oxidise benzaldehyde with the warm permanganate"
    phase: 1
    prerequisites:
    - prepare-permanganate
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: "KMnO4 oxidises benzaldehyde to benzoic acid \u2014 the violet discharges and brown MnO2 forms.\n\u2192 Squeeze 2 dropper-loads of benzaldehyde into the beaker, then warm the beaker at the water bath (pour distilled water in, lit burner beside it)."
  - taskId: filter-mno2
    label: "Filter off the brown MnO2"
    phase: 1
    prerequisites:
    - oxidise-benzaldehyde
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: "The benzoic acid stays dissolved; the brown manganese dioxide is sludge to remove.\n\u2192 Hold the funnel over the Erlenmeyer flask and tilt-pour the beaker through it (about 20 ml)."
  - taskId: acidify
    label: "Acidify the filtrate with 6N HCl"
    phase: 1
    prerequisites:
    - filter-mno2
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: "Acid turns the dissolved benzoate back into insoluble benzoic acid \u2014 white crystals separate.\n\u2192 Squeeze 5 dropper-loads of 6N hydrochloric acid into the flask."
  - taskId: crystallise
    label: "Chill in the ice bath; crystallise"
    phase: 1
    prerequisites:
    - acidify
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: "Cold completes the crystallisation; recrystallising from hot water then purifies the crystals.\n\u2192 Set the flask in the ice bucket and let it chill."
    longProcess: 1
    longProcessMessage: "The flask chilled in the ice \u2014 the crystals grew, were recrystallised from hot water and dried."
  - taskId: test-litmus
    label: "Litmus test \u2014 blue litmus turns red"
    phase: 2
    prerequisites:
    - crystallise
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "A carboxylic acid turns blue litmus red.\n\u2192 Scoop 1 scoopula of your crystals (2 g) into Test Tube 8, add 2 squeezes of distilled water, then touch a litmus strip to it."
  - taskId: test-fecl3
    label: "Ferric chloride test \u2014 buff precipitate"
    phase: 2
    prerequisites:
    - crystallise
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Neutralised to benzoate, ferric chloride drops a buff/salmon precipitate.\n\u2192 Into Test Tube 9: 1 scoopula of crystals, 2 squeezes of 10% NaOH, then 5 squeezes of ferric chloride."
  - taskId: test-ester
    label: "Ester test \u2014 fruity odour with propyl alcohol"
    phase: 2
    prerequisites:
    - crystallise
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Warmed with propyl alcohol and a drop of sulfuric acid, benzoic acid gives a sweet ester odour (shown on screen).\n\u2192 Into Test Tube 10: 1 scoopula of crystals, 10 squeezes of propyl alcohol, 1 of sulfuric acid \u2014 then warm it at the water bath."
  - taskId: record-yield
    label: "Record yield and observations"
    phase: 3
    prerequisites:
    - test-litmus
    - test-fecl3
    - test-ester
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: "Crystal mass, % yield and each test result go on the data sheet.\n\u2192 Review the results, then answer on the tablet."
    autoCompleteWhenOthersDone: 1
  assessmentMode: 0
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.3
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills:
  - 5
  - 2
  - 0
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 900
