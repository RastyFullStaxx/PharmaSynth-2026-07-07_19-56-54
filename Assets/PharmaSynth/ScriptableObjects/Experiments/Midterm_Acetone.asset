%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Midterm_Acetone
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: midterm-acetone
  moduleTitle: 'Midterm 3: Acetone'
  intendedLearningOutcomes:
  - 'Objective 1: Synthesize acetone.'
  - 'Objective 2: Determine its identity through chemical tests.'
  materialReagents:
  - "Calcium Acetate \u2014 7 g (4 scoopula dips)"
  - "Sodium Acetate \u2014 7 g (4 scoopula dips)"
  - "Silver Nitrate \u2014 2 squeezes (Tollen's stand-in)"
  - "Schiff's Reagent \u2014 5 squeezes"
  - "Potassium Iodide 10% \u2014 10 squeezes"
  - "Sodium Hypochlorite \u2014 10 squeezes"
  - "Sodium Bisulfite \u2014 2 squeezes"
  - "Ethanol \u2014 1 squeeze"
  - "Distilled Water \u2014 5 squeezes (Tollen's tube)"
  materialApparatus:
  - "HARD-GLASS tube (the only open-flame glass)"
  - "Balance (weigh the acetates live)"
  - "Bunsen burner (open flame, 150 \u00B0C glow)"
  - "Test tubes 14\u201318 (receiver + 4 tests)"
  - "Water bath + burner (iodoform warm)"
  - "Ice bucket (bisulfite freezing mixture)"
  - "Scoopula + Dropper"
  tasks: []
  graphTasks:
  - taskId: weigh-acetates
    label: "Weigh 7 g of each acetate into the hard-glass tube"
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "7 g calcium acetate + 7 g sodium acetate decompose on strong heat into acetone.\n\u2192 Set the HARD-GLASS tube on the balance, then scoop 4 scoopula dips of EACH acetate into it (watch the grams)."
  - taskId: heat-glow
    label: "Heat the tube over the open flame until the acetates glow"
    phase: 1
    prerequisites:
    - weigh-acetates
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: "Dry distillation needs REAL heat \u2014 far beyond the water bath. Only the hard-glass tube survives an open flame.\n\u2192 Light a burner and hold the tube over its flame until it reaches a red-glow 150 \u00B0C."
  - taskId: collect-56
    label: "Collect the acetone distillate at 56 \u00B0C"
    phase: 1
    prerequisites:
    - heat-glow
    progressWeight: 1
    skill: 4
    rubricCategory: 0
    required: 1
    hint: "Acetone boils at 56 \u00B0C \u2014 the vapour condenses in a cool receiver.\n\u2192 Keep Test Tube 14 close to the hot tube's mouth; the distillate collects there while the tube stays hot."
  - taskId: test-tollens
    label: "Tollen's test \u2014 NO silver mirror (ketone)"
    phase: 2
    prerequisites:
    - collect-56
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Ketones resist mild oxidation: Tollen's (ammoniacal silver nitrate) gives NO mirror \u2014 the negative IS the result.\n\u2192 Test Tube 15: 2 of your acetone + 5 water + 2 squeezes of silver nitrate."
  - taskId: test-schiff
    label: "Schiff's reagent \u2014 no magenta (ketone)"
    phase: 2
    prerequisites:
    - collect-56
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Schiff's reagent stays colourless with ketones \u2014 another deliberate negative.\n\u2192 Test Tube 16: 5 squeezes of Schiff's reagent + 2 of your acetone; let it stand."
  - taskId: test-iodoform
    label: "Iodoform test \u2014 yellow precipitate"
    phase: 2
    prerequisites:
    - collect-56
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "A methyl ketone gives the yellow iodoform precipitate with KI + hypochlorite, warmed.\n\u2192 Test Tube 17: 10 of KI + 2 of your acetone + 10 of hypochlorite, then warm it at the water bath."
  - taskId: test-bisulfite
    label: "Bisulfite addition product \u2014 in the freezing mixture"
    phase: 2
    prerequisites:
    - collect-56
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Methyl ketones form a white crystalline adduct with saturated bisulfite, clearest when chilled.\n\u2192 Test Tube 18: 1 of ethanol + 2 of sodium bisulfite + 1 of your acetone, then set it in the ice bucket."
  - taskId: record-yield
    label: "Record % yield and observations"
    phase: 3
    prerequisites:
    - test-tollens
    - test-schiff
    - test-iodoform
    - test-bisulfite
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: "Distillate mass, % yield and all four test results go on the data sheet.\n\u2192 Review the results, then answer on the tablet."
    autoCompleteWhenOthersDone: 1
  assessmentMode: 0
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.3
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills:
  - 5
  - 0
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 1000
