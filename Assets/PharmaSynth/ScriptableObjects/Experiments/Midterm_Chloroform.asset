%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 951a6ee5ea398d74bb35c9fb7a4d1939, type: 3}
  m_Name: Midterm_Chloroform
  m_EditorClassIdentifier: Assembly-CSharp::ExperimentModuleDefinition
  moduleId: midterm-chloroform
  moduleTitle: 'Midterm 4: Chloroform'
  intendedLearningOutcomes:
  - Prepare chloroform by the haloform reaction of acetone with bleaching powder
  - Purify by decantation and distillation over CaCl2
  - Confirm by non-flammability and alcoholic silver-nitrate tests
  materialReagents:
  - "Bleaching Powder \u2014 150 g (5 scoopula dips)"
  - "Distilled Water \u2014 flask 20 ml + cylinder 10 ml + wash 4 squeezes"
  - "Acetone \u2014 12 g in 50 ml water (5 ml pour + 5 dropper squeezes)"
  - "Anhydrous Calcium Chloride \u2014 1 scoopula"
  - "Potassium Dichromate \u2014 4 spatula dips (fume hood)"
  - "Sulfuric Acid (conc.) \u2014 2 squeezes"
  - "Alcoholic Silver Nitrate \u2014 1 squeeze"
  materialApparatus:
  - "Erlenmeyer Flask 400 mL (the 1 L reaction flask)"
  - "Graduated Cylinder 50 mL (the separatory-funnel stand-in)"
  - "Beaker 100 mL (crude receiver + wash)"
  - "Distilling Flask (CaCl2 dry + redistil)"
  - "Test Tubes 14\u201316 (product, oxidation, AgNO3)"
  - "Watch Glass (flammability sample)"
  - "Water bath + burner \u00B7 Balance \u00B7 Fume hood"
  - "Scoopula + spatula + dropper \u00B7 Matches"
  tasks: []
  graphTasks:
  - taskId: prep-bleach
    label: "Dissolve 150 g bleaching powder in 400 mL water (1 L flask)"
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "150 g of fresh bleaching powder shaken with 400 ml of water frees the hypochlorite for the haloform reaction.\n\u2192 Erlenmeyer Flask 400 mL: scoop 5 scoopula dips of bleaching powder in FIRST, then tilt-pour distilled water to 20 ml."
  - taskId: prep-acetone-mix
    label: "Mix 12 g acetone + 50 mL water (the dropwise charge)"
    phase: 0
    prerequisites: []
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "The manuscript dilutes 12 g of acetone with 50 ml of water so it can be added gently.\n\u2192 Graduated Cylinder 50 mL: tilt-pour acetone to 5 ml, then a 10 ml tilt-pour of distilled water."
  - taskId: add-dropwise
    label: "Add the acetone-water mixture drop by drop"
    phase: 1
    prerequisites:
    - prep-bleach
    - prep-acetone-mix
    progressWeight: 1
    skill: 3
    rubricCategory: 0
    required: 1
    hint: "Drop by drop \u2014 the haloform reaction is exothermic; dumped in at once it boils over.\n\u2192 Dropper 5 squeezes of the acetone mix into the flask, then warm the flask to 40 \u00B0C at the water bath \u2014 watch the dense chloroform form."
  - taskId: distil
    label: "Arrange for distillation \u2014 bring the flask to the boil"
    phase: 1
    prerequisites:
    - add-dropwise
    progressWeight: 1
    skill: 1
    rubricCategory: 0
    required: 1
    hint: "Chloroform boils at 61 \u00B0C \u2014 comfortably under the bath's 100 \u00B0C cap.\n\u2192 Keep the flask in the water bath (lit burner beside it) until its label reads 65 \u00B0C."
  - taskId: collect-crude
    label: "Collect the crude chloroform distillate"
    phase: 1
    prerequisites:
    - distil
    progressWeight: 1
    skill: 4
    rubricCategory: 0
    required: 1
    hint: "At the boil the chloroform vapour condenses in any cool vessel held at the mouth.\n\u2192 Hold Beaker 100 mL beside the hot flask \u2014 8 ml of crude chloroform run over."
  - taskId: decant-wash
    label: "Wash the chloroform by decantation (\u00D72)"
    phase: 1
    prerequisites:
    - collect-crude
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: "Water washes out lime and free alkali; chloroform is DENSER and settles under the wash. The manual repeats the wash twice.\n\u2192 Squeeze 4 of distilled water into Beaker 100 mL and swirl \u2014 the next step decants the bottom layer off."
  - taskId: dry-cacl2
    label: "Dry the washed chloroform over anhydrous CaCl2"
    phase: 1
    prerequisites:
    - decant-wash
    progressWeight: 1
    skill: 2
    rubricCategory: 0
    required: 1
    hint: "Anhydrous calcium chloride drinks up the last of the water before the final distillation.\n\u2192 Decant (tilt-pour) 8 ml of the dense chloroform into the Distilling Flask, add 1 scoopula of anhydrous calcium chloride, then warm it to 65 \u00B0C at the bath."
  - taskId: dry-redistil
    label: "Redistil until the liquid runs clear"
    phase: 1
    prerequisites:
    - dry-cacl2
    progressWeight: 1
    skill: 4
    rubricCategory: 0
    required: 1
    hint: "Redistilling off the drying agent leaves water-clear chloroform \u2014 no droplets on the glass.\n\u2192 Keep the Distilling Flask hot; hold Test Tube 14 at its mouth until 6 ml run over clear."
  - taskId: weigh-product
    label: "Weigh your chloroform distillate"
    phase: 1
    prerequisites:
    - dry-redistil
    progressWeight: 1
    skill: 0
    rubricCategory: 0
    required: 1
    hint: "The data sheet needs your distillate's mass for the percentage yield.\n\u2192 Set Test Tube 14 on the balance and let the reading settle."
  - taskId: test-flammability
    label: "Non-flammability test (lit match)"
    phase: 2
    prerequisites:
    - weigh-product
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Unlike its acetone feedstock, chloroform will NOT burn \u2014 the negative IS the result.\n\u2192 Pour 2 ml (4 tilt-pours) of your chloroform onto the Watch Glass, then strike a match and hold the flame to it."
  - taskId: test-oxidation
    label: "Oxidation test \u2014 dichromate + conc. H2SO4 (fume hood)"
    phase: 2
    prerequisites:
    - weigh-product
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Hot dichromate + concentrated sulfuric acid oxidise chloroform \u2014 the pungent phosgene-like odour is the tell. Toxic: work IN the fume hood.\n\u2192 Test Tube 15 in the hood: 2 tilt-pours of your chloroform, 4 spatula dips of potassium dichromate, 2 squeezes of sulfuric acid \u2014 then warm it at the water bath."
  - taskId: test-agno3
    label: "Alcoholic AgNO3 \u2014 nothing cold, white AgCl warm"
    phase: 2
    prerequisites:
    - weigh-product
    progressWeight: 1
    skill: 5
    rubricCategory: 1
    required: 1
    hint: "Alcoholic silver nitrate shows NOTHING in the cold \u2014 only on warming does white silver chloride separate.\n\u2192 Test Tube 16: 1 squeeze of alcoholic silver nitrate FIRST, then 2 tilt-pours of your chloroform. Warm it at the water bath and watch for the white precipitate."
  - taskId: record-yield
    label: "Record % yield and observations"
    phase: 3
    prerequisites:
    - weigh-product
    - test-flammability
    - test-oxidation
    - test-agno3
    progressWeight: 1
    skill: 0
    rubricCategory: 5
    required: 1
    hint: "Mass, % yield and all three test results go on the data sheet.\n\u2192 Review your observations, then answer on the tablet."
    autoCompleteWhenOthersDone: 1
  assessmentMode: 0
  masteryThreshold: 0.9
  bkt:
    pL0: 0.25
    pTransit: 0.2
    pSlip: 0.1
    pGuess: 0.2
  trackedSkills:
  - 0
  - 5
  - 4
  - 2
  rubricWeights:
    procedure: 0.4
    chemicalTests: 0.2
    materialsAndPPE: 0.15
    timeManagement: 0.1
    sanitation: 0.1
    documentation: 0.05
  parTimeSeconds: 1100
