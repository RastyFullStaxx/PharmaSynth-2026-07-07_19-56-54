  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2aaa93f2aa9be4d4babad2427d4a3c02, type: 3}
  m_Name: Quiz_ChemicalCompounding
  m_EditorClassIdentifier: Assembly-CSharp::QuizBank
  moduleId: prelim-chemical-compounding
  questions:
  - prompt: Ethanol contains which functional group?
    options:
    - Carbonyl
    - Hydroxyl
    - Carboxyl
    - Amino
    correctIndex: 1
    explanation: Ethanol is an alcohol (hydroxyl, -OH).
  - prompt: 'Adding sodium metal to ethanol produces:'
    options:
    - Oxygen
    - Methane
    - Hydrogen gas
    - Chlorine
    correctIndex: 2
    explanation: Sodium displaces the -OH hydrogen, releasing hydrogen gas.
  - prompt: What shows that potassium permanganate has OXIDISED an alcohol?
    options:
    - The purple colour fades / turns brown
    - The mixture freezes
    - White smoke appears
    - Nothing changes
    correctIndex: 0
    explanation: "KMnO4's violet colour is discharged (brown MnO2 forms) as it oxidises
      the alcohol \u2014 the manuscript's rate-of-oxidation test."
